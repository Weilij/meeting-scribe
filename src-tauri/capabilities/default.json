{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "fs:allow-write-file",
    "fs:allow-read-file",
    "fs:allow-temp-write-recursive",
    "fs:allow-temp-read-recursive",
    "core:path:allow-resolve",
    "core:path:allow-join"
  ]
}
